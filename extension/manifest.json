{
  "manifest_version": 3,
  "name": "PODStudio 采集助手",
  "version": "0.3.1",
  "description": "在 Temu 商品页一键采集整页商品(图+标题+价格+评分+链接)到 PODStudio 采集箱,勾选同步入库。",
  "permissions": ["storage"],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "host_permissions": [
    "*://*.temu.com/*",
    "*://*.kwcdn.com/*",
    "*://*.temucdn.com/*",
    "https://pod.kejing.online/*",
    "http://localhost:10000/*",
    "http://localhost:5173/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PODStudio 采集助手",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.temu.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://pod.kejing.online/*", "http://localhost:5173/*", "http://localhost:10000/*"],
      "js": ["auth.js"],
      "run_at": "document_idle"
    }
  ]
}
