# 复制为 .env 并填入你的值

# 抠图用 gpt-image(image2):pillow | rembg | api | gptimage
POD_MATTING_PROVIDER=gptimage

# OpenAI gpt-image-1（"image2"）
POD_OPENAI_API_KEY=sk-xxxxxxxx
POD_OPENAI_IMAGE_MODEL=gpt-image-1
# 走代理/兼容网关时填,官方留空
# POD_OPENAI_BASE_URL=https://your-proxy/v1

# 放大保持本地超分(gpt-image 不做超分,见 README)
POD_UPSCALE_PROVIDER=pillow
