# 复制为 .env 并按需填写。本文件已被 .gitignore,key 不会进 git。
#
# ⭐ 强烈建议:立刻填好下面的 POD_OPENAI_API_KEY。
#    很多功能都依赖它 —— 文生图、图生图/改图、换装/换背景、印花提取(默认 AI 重绘)、
#    作图工具(裂变/融合/风格转绘)等。没 key 这些会 502 或降级到占位/本地兜底。
#    抠图和放大可以纯本地(见下),但完整 AI 能力必须有 key。

# ===== OpenAI 兼容网关 / OpenAI 官方 =====
POD_OPENAI_API_KEY=sk-xxxxxxxx
# 用第三方/兼容网关时填其地址;用 OpenAI 官方则留空
# POD_OPENAI_BASE_URL=https://your-gateway/v1
# 图像模型 id:官方用 gpt-image-1;部分网关提供更新的 gpt-image-2
POD_OPENAI_IMAGE_MODEL=gpt-image-1

# ===== 数据库 POD_DATABASE_URL(必填,项目已全面转 MySQL,不再支持 SQLite)=====
#   先建库 + 独立用户(只授该库,utf8mb4),再填连接串(pymysql+cryptography 已在 requirements):
#     CREATE DATABASE podsys CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#     CREATE USER 'podsys'@'127.0.0.1' IDENTIFIED BY '你的密码';
#     GRANT ALL PRIVILEGES ON podsys.* TO 'podsys'@'127.0.0.1';
POD_DATABASE_URL=mysql+pymysql://podsys:你的密码@127.0.0.1:3306/podsys?charset=utf8mb4
#   跑测试还需一个 *_test 隔离库(conftest 会自动用它,绝不碰真实库):
#     CREATE DATABASE podsys_test CHARACTER SET utf8mb4; GRANT ALL ON podsys_test.* TO 'podsys'@'127.0.0.1';

# ===== 抠图引擎 POD_MATTING_PROVIDER:rembg | pillow | gptimage | api =====
#   rembg   = 本地神经网络 U2Net(默认,推荐):离线免费、复杂背景/人物也干净。
#             依赖已在 requirements.txt;首次抠图自动下载 ~170MB 模型(需一次联网)。
#   pillow  = 四角背景色距离抠图,纯 CPU、零下载;仅适合纯色/干净背景产品图。
#   gptimage= 走上面的网关 gpt-image(需 key)。
#   api     = 第三方 HTTP 抠图 API(配 POD_MATTING_API_URL / POD_MATTING_API_KEY)。
POD_MATTING_PROVIDER=rembg

# ===== 放大引擎 POD_UPSCALE_PROVIDER:pillow | fsrcnn =====
# ⚠️ 放大绝不能用 gpt-image(生成模型会重绘像素、毁印花)。
#   pillow = Lanczos,纯 CPU、无需模型(默认)
#   fsrcnn = 快·略清晰,需 backend/models/FSRCNN_x4.pb
# 模型文件不在仓库里,下载/放置见 backend/models/README.md;缺失时自动降级 Lanczos。
POD_UPSCALE_PROVIDER=pillow

# ===== AI 图生视频 POD_VIDEO_PROVIDER:local | cogvideox =====
# 图生视频(上传 1 张=让它动起来 / 2 张=首尾帧过渡 + 文字描述运动)。可插拔 Provider:
#   local     = 不调 AI,用本地 Ken-Burns/轮播出 GIF —— 离线兜底,无 key 也能出东西(降级,非真视频,默认)
#   cogvideox = 智谱开放平台 CogVideoX-3(真视频 mp4)。开通步骤:
#               ① 注册 https://open.bigmodel.cn/ → 实名 → 充值;② 拿 API Key 填 POD_VIDEO_API_KEY;
#               ③ POD_VIDEO_PROVIDER=cogvideox。业务/前端不动,填好即用。文档:
#               https://docs.bigmodel.cn/cn/guide/models/video-generation/cogvideox-3
POD_VIDEO_PROVIDER=local
POD_VIDEO_API_KEY=
# 下面都有默认值,一般不用改。不暴露给前端选(扣费与分辨率无关,按画幅直接用高分辨率)。
# POD_VIDEO_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# POD_VIDEO_MODEL=cogvideox-3
# POD_VIDEO_QUALITY=quality        # quality(质量优先) | speed
# POD_VIDEO_FPS=30                 # 30 | 60
# POD_VIDEO_SECONDS=10             # 5 | 10
# POD_VIDEO_WITH_AUDIO=true        # 有声(主打巴西/葡语市场;设 false 出无声视频)
# POD_VIDEO_SIZE=                  # 留空=按画幅取高分辨率;填则强制(如 3840x2160 上 4K)
# POD_VIDEO_TIMEOUT=1500           # 轮询总超时(秒);视频远比图片慢,默认 25min(4K/排队真要这么久)
# POD_VIDEO_POLL_INTERVAL=5

# ===== 对象存储 POD_STORAGE_BACKEND:local | s3(MinIO/S3 兼容)=====
# local = 纯本地磁盘(默认,所有对象层函数 no-op,行为与今天一致)。
# s3    = 本地盘当写缓存 + MinIO 当存储 of record:作业收尾镜像产物进 MinIO,/files 本地缺失自动回源,
#         删除两边都删。生产 MinIO 部署在 127.0.0.1:9000(localhost-only,与旁边 Django 物理隔离)。
#         换阿里云 OSS / 腾讯 COS 只需填它们的 S3 兼容 endpoint/密钥,业务/前端不动。
# ⚠️ 真实 access/secret 只填到 backend/.env(已 gitignore),绝不要提交真值到本文件。
POD_STORAGE_BACKEND=local
# POD_S3_ENDPOINT_URL=http://127.0.0.1:9000   # 官方 AWS S3 留空;MinIO/OSS/COS 填其 endpoint
# POD_S3_REGION=us-east-1
# POD_S3_ACCESS_KEY=                           # = MinIO 的 MINIO_ROOT_USER(或独立 access key)
# POD_S3_SECRET_KEY=                           # = MinIO 的 MINIO_ROOT_PASSWORD(或独立 secret key)
# POD_S3_BUCKET=podsys
# POD_S3_ADDRESSING=path                       # MinIO 必须 path-style;AWS 可 virtual
# POD_S3_MIRROR_UPLOADS=false                  # 是否连输入图也镜像(默认只镜像产物)
# POD_S3_RETENTION_DAYS=0                      # >0:清早于 N 天的本地产物缓存(MinIO 已有副本)。0=不清理
#                                              #   ⚠️ 开启前必须先把 quota 改成以 DB 为准(见计划阶段三)
