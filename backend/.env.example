# 复制为 .env 并按需填写。本文件已被 .gitignore,key 不会进 git。
#
# ⭐ 强烈建议:立刻填好下面的 POD_OPENAI_API_KEY。
#    很多功能都依赖它 —— 文生图、图生图/改图、换装/换背景、印花提取(默认 AI 重绘)、
#    作图工具(裂变/融合/风格转绘)等。没 key 这些会 502 或降级到占位/本地兜底。
#    抠图和放大可以纯本地(见下),但完整 AI 能力必须有 key。

# ===== OpenAI 兼容网关 / OpenAI 官方 =====
POD_OPENAI_API_KEY=sk-xxxxxxxx
# 用第三方/兼容网关时填其地址;用 OpenAI 官方则留空
# POD_OPENAI_BASE_URL=https://your-gateway/v1
# 图像模型 id:官方用 gpt-image-1;部分网关提供更新的 gpt-image-2
POD_OPENAI_IMAGE_MODEL=gpt-image-1

# ===== 数据库 POD_DATABASE_URL =====
#   留空 = SQLite(backend/data/podstudio.db;零依赖,适合本地起步/测试,pytest 永远用它)。
#   切 MySQL(dev/prod 推荐):先建库+独立用户(utf8mb4),再填连接串(需 pip install pymysql cryptography,已在 requirements):
# POD_DATABASE_URL=mysql+pymysql://podsys:你的密码@127.0.0.1:3306/podsys?charset=utf8mb4
#   已有 SQLite 数据 → 用 backend/scripts/migrate_sqlite_to_mysql.py 搬过去(保留 ID)。

# ===== 抠图引擎 POD_MATTING_PROVIDER:rembg | pillow | gptimage | api =====
#   rembg   = 本地神经网络 U2Net(默认,推荐):离线免费、复杂背景/人物也干净。
#             依赖已在 requirements.txt;首次抠图自动下载 ~170MB 模型(需一次联网)。
#   pillow  = 四角背景色距离抠图,纯 CPU、零下载;仅适合纯色/干净背景产品图。
#   gptimage= 走上面的网关 gpt-image(需 key)。
#   api     = 第三方 HTTP 抠图 API(配 POD_MATTING_API_URL / POD_MATTING_API_KEY)。
POD_MATTING_PROVIDER=rembg

# ===== 放大引擎 POD_UPSCALE_PROVIDER:pillow | fsrcnn =====
# ⚠️ 放大绝不能用 gpt-image(生成模型会重绘像素、毁印花)。
#   pillow = Lanczos,纯 CPU、无需模型(默认)
#   fsrcnn = 快·略清晰,需 backend/models/FSRCNN_x4.pb
# 模型文件不在仓库里,下载/放置见 backend/models/README.md;缺失时自动降级 Lanczos。
POD_UPSCALE_PROVIDER=pillow
